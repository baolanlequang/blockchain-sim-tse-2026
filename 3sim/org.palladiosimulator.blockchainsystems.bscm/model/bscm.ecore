          eType="#//p2pnetwork/P2PNetwork"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="Specification" lowerBound="1"
          eType="#//blockchainsystem/BlockchainSystemSpecification" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="TransactionsSpecification"
          lowerBound="1" eType="#//transactions/TransactionsSpecification"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="GeographicalRegionsSpecification"
          lowerBound="1" eType="#//geographicalregions/GeographicalRegionsSpecification"/>
