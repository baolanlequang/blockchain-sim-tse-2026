    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="linkallocation" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/LinkAllocation/1.0"
      nsPrefix="linkallocation">
    <eClassifiers xsi:type="ecore:EClass" name="LinkAllocationRepository" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="LinkAllocations" upperBound="-1"
