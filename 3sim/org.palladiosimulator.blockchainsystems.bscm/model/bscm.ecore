      <eStructuralFeatures xsi:type="ecore:EReference" name="throughputSpecification"
          lowerBound="1" eType="#//linkallocation/LinkThroughputSpecification" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="bandwidthSpecification"
          lowerBound="1" eType="#//linkallocation/BandwidthSpecification" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="LinkLatencySpecification" abstract="true"
