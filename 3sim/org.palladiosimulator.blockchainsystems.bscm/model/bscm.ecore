<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="bscm" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/1.0"
    nsPrefix="bscm">
  <eSubpackages name="nodeallocation" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/NodeAllocation/1.0"
      nsPrefix="nodeallocation">
    <eClassifiers xsi:type="ecore:EClass" name="NodeAllocation" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="AllocationContexts" upperBound="-1"
          eType="#//nodeallocation/NodeAllocationContext" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="NodeAllocationEnvironment"
          lowerBound="1" eType="#//nodeenvironment/NodeEnvironment" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="NodeSystem" lowerBound="1"
          eType="#//nodesystem/BlockchainSystemNodeSystem" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="GeographicalRegion" lowerBound="1"
          eType="#//geographicalregions/GeographicalRegion"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="NodeAllocationRepository" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="NodeAllocations" upperBound="-1"
          eType="#//nodeallocation/NodeAllocation" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="NodeAllocationContext" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="AssemblyContext" lowerBound="1"
          eType="#//nodesystem/BlockchainSystemNodeAssemblyContext"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="ResourceContainer" eType="#//nodeenvironment/NodeResourceContainer"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="nodesystem" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/NodeSystem/1.0"
      nsPrefix="nodesystem">
    <eClassifiers xsi:type="ecore:EClass" name="BlockchainSystemNodeSystem" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="MiningProcessAssembly"
          lowerBound="1" eType="#//nodesystem/BlockchainSystemNodeAssemblyContext"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="BlockValidatorAssembly"
          lowerBound="1" eType="#//nodesystem/BlockchainSystemNodeAssemblyContext"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="AssemblyContexts" upperBound="-1"
          eType="#//nodesystem/BlockchainSystemNodeAssemblyContext" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="Behavior" lowerBound="1"
          eType="#//nodesystem/NodeBehaviorSpecification" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="BlockchainSystemNodeAssemblyContext"
        eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="EncapsulatedComponent"
          lowerBound="1" eType="#//blockchainsystemComponentRepository/BlockchainSystemNodeComponent"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="NodeBehaviorSpecification" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="Behavior" lowerBound="1"
          eType="#//nodesystem/NodeBehavior"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="NodeBehavior">
      <eLiterals name="Honest"/>
      <eLiterals name="Malicious" value="1"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="blockchainsystemComponentRepository" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/BlockchainSystemComponentRepository/1.0"
      nsPrefix="blockchainsystemComponentRepository">
    <eClassifiers xsi:type="ecore:EClass" name="BlockchainSystemNodeComponent" abstract="true"
        eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity"/>
    <eClassifiers xsi:type="ecore:EClass" name="BlockchainSystemNodeComponentRepository"
        eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Components" upperBound="-1"
          eType="#//blockchainsystemComponentRepository/BlockchainSystemNodeComponent"
          containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="BlockValidatorComponent" eSuperTypes="#//blockchainsystemComponentRepository/BlockchainSystemNodeComponent">
      <eStructuralFeatures xsi:type="ecore:EReference" name="ValidationDuration" lowerBound="1"
          eType="#//blockchainsystemComponentRepository/BlockValiationDurationSpecification"
          containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="crashed" eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EBoolean"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="MiningProcessComponent" eSuperTypes="#//blockchainsystemComponentRepository/BlockchainSystemNodeComponent">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="IsMiningProcessEnabled"
          lowerBound="1" eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EBoolean"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="BlockValiationDurationSpecification"
        eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Values" lowerBound="1"
          upperBound="-1" eType="#//blockchainsystemComponentRepository/BlockValidationDurationValue"
          containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="BlockValidationDurationValue" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="Duration" lowerBound="1"
          eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//ELong"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="Probability" lowerBound="1"
          eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EDouble"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="p2pnetwork" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/P2PNetwork/1.0"
      nsPrefix="P2PNetwork">
    <eClassifiers xsi:type="ecore:EClass" name="P2PNetwork" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Topology" lowerBound="1"
          eType="#//p2pnetwork/NetworkTopology" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="NetworkTopology" abstract="true" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity"/>
    <eClassifiers xsi:type="ecore:EClass" name="ExplicitNetworkTopology" eSuperTypes="#//p2pnetwork/NetworkTopology">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Nodes" upperBound="-1"
          eType="#//p2pnetwork/Node" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="Links" upperBound="-1"
          eType="#//p2pnetwork/Link" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ConstraintNetworkTopology" abstract="true"
        eSuperTypes="#//p2pnetwork/NetworkTopology"/>
    <eClassifiers xsi:type="ecore:EClass" name="Node" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Allocation" lowerBound="1"
          eType="#//nodeallocation/NodeAllocation"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="Link" abstract="true" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Allocation" lowerBound="1"
          eType="#//linkallocation/LinkAllocation"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ConnectedSubgraphsNetworkTopology"
        eSuperTypes="#//p2pnetwork/ConstraintNetworkTopology">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Subgraphs" lowerBound="1"
          upperBound="-1" eType="#//p2pnetwork/SubgraphSpecification" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="SubgraphLinks" upperBound="-1"
          eType="#//p2pnetwork/SubgraphLink" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="SubgraphSpecification" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="NodeTemplates" lowerBound="1"
          upperBound="-1" eType="#//p2pnetwork/SubgraphNodeTemplate" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="Connectivity" lowerBound="1"
          eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EInt"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="LinkAllocation" lowerBound="1"
          eType="#//linkallocation/LinkAllocation"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="ConnectivitySpecification"
          lowerBound="1" eType="#//p2pnetwork/ConnectivitySpecification" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="ConnectivitySpecification" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="InBoundLinkAllocationSpecification"
          lowerBound="1" eType="#//linkallocation/LinkAllocation"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="OutBoundLinkAllocationSpecification"
          lowerBound="1" eType="#//linkallocation/LinkAllocation"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="NumberOfInbound" lowerBound="1"
          eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EInt"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="NumberOfOutBound" lowerBound="1"
          eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EInt"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="SubgraphLink" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="Allocation" lowerBound="1"
          eType="#//linkallocation/LinkAllocation" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="ConnectedSubgraphs" lowerBound="2"
          upperBound="2" eType="#//p2pnetwork/SubgraphSpecification"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="SubgraphNodeTemplate" eSuperTypes="../../org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="NumberOfNodeOccurences"
          lowerBound="1" eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EInt"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="Allocation" lowerBound="1"
          eType="#//nodeallocation/NodeAllocation"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="IsSubgraphProxy" lowerBound="1"
          eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EBoolean"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="BidirectionalLink" eSuperTypes="#//p2pnetwork/Link">
      <eStructuralFeatures xsi:type="ecore:EReference" name="ConnectedNodes" lowerBound="2"
          upperBound="2" eType="#//p2pnetwork/Node"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="UnidirectionalLink" eSuperTypes="#//p2pnetwork/Link">
      <eStructuralFeatures xsi:type="ecore:EReference" name="FromNode" lowerBound="1"
          eType="#//p2pnetwork/Node"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="ToNode" lowerBound="1"
          eType="#//p2pnetwork/Node"/>
    </eClassifiers>
  </eSubpackages>
  <eSubpackages name="blockchainsystem" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/BlockchainSystem/1.0"
