      <eStructuralFeatures xsi:type="ecore:EAttribute" name="MeanTransactionCreationInterval"
          lowerBound="1" eType="ecore:EDataType platform:/plugin/org.eclipse.emf.ecore/model/Ecore.ecore#//EDouble"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="TransactionPropertiesSpecification"
          lowerBound="1" eType="#//transactions/TransactionPropertiesSpecification"
